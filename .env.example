# ========================================
# Philtech Payroll System - .env Configuration
# ========================================
# Copy this file to .env and fill in your values

# ========== DATABASE CONFIGURATION ==========
# For Render deployment - get DATABASE_URL from Render dashboard
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/payroll_db

# OR use individual environment variables for local development:
# PGHOST=localhost
# PGPORT=5432
# PGUSER=postgres
# PGPASSWORD=your_password
# PGDATABASE=payroll_db

# ========== APPLICATION SETTINGS ==========
PORT=10000
NODE_ENV=development

# Optional: PHP session file directory (must exist and be writable). Useful on Render
# if default /tmp session files are lost on restart; point to a mounted disk path.
# SESSION_SAVE_PATH=/var/data/php-sessions

# Temporary: set to 1 to enable GET /api/auth/session_diagnostics.php (then unset after debugging).
# SESSION_DIAGNOSTICS=0

# ========== FIREBASE CONFIGURATION (OPTIONAL) ==========
# Get this from Firebase Console > Project Settings > Service Account
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account",...}
